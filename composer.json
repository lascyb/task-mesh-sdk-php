{
    "name": "taskmesh/sdk-php",
    "version": "1.1.2",
    "description": "Task Mesh Worker 埋点 SDK，用于向 Task Mesh 上报 runStart / runFinish / event",
    "type": "library",
    "keywords": [
        "task-mesh",
        "taskmesh",
        "worker",
        "tracking",
        "cron",
        "sdk"
    ],
    "license": "Apache-2.0",
    "homepage": "https://github.com/lascyb/task-mesh-sdk-php",
    "support": {
        "issues": "https://github.com/lascyb/task-mesh-sdk-php/issues",
        "source": "https://github.com/lascyb/task-mesh-sdk-php"
    },
    "authors": [
        {
            "name": "lascyb",
            "email": "lascyb@qq.com"
        }
    ],
    "require": {
        "php": ">=8.0.2",
        "ext-json": "*",
        "ext-curl": "*"
    },
    "autoload": {
        "psr-4": {
            "taskmesh\\sdk\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
